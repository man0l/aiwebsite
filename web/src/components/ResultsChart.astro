---
interface Props {
  results: any;
}
const { results } = Astro.props;

const resultsHeading    = results?.heading    ?? 'Data-Backed Growth';
const resultsSubheading = results?.subheading ?? "Below is an example of a typical agency's pipeline growth.";
const dataPoints: any[] = results?.dataPoints?.length ? results.dataPoints : [
  { label: 'Month 1', value: 1 },
  { label: 'Month 2', value: 3 },
  { label: 'Month 3', value: 5 },
  { label: 'Month 4', value: 7 },
];
const labels = JSON.stringify(dataPoints.map((d: any) => d.label ?? d.month ?? ''));
const values = JSON.stringify(dataPoints.map((d: any) => d.value ?? d.meetings ?? 0));
---

<section id="results" class="py-20 bg-brand-dark border-t border-gray-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-5xl font-display font-bold text-white text-center mb-4">
      {resultsHeading}
    </h2>
    <p class="text-brand-gray text-lg text-center max-w-2xl mx-auto mb-12">
      {resultsSubheading}
    </p>

    <div class="chart-container">
      <canvas id="resultsChart"></canvas>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script type="module" define:vars={{ labels, values }}>
  const LABELS = JSON.parse(labels);
  const VALUES = JSON.parse(values);
  const ctx = document.getElementById('resultsChart');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: LABELS,
      datasets: [{
        label: 'Qualified Meetings',
        data: VALUES,
        backgroundColor: '#BEF264',
        borderRadius: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: '#AAAAAA' } }
      },
      scales: {
        x: { ticks: { color: '#AAAAAA' }, grid: { color: '#374151' } },
        y: { ticks: { color: '#AAAAAA' }, grid: { color: '#374151' }, beginAtZero: true }
      }
    }
  });
</script>

<style>
  .chart-container {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    height: 350px;
  }
  @media (min-width: 768px) {
    .chart-container { height: 400px; }
  }
</style>
