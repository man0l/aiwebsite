---
interface Props {
  cta: any;
}
const { cta } = Astro.props;
const ctaHeading       = cta?.heading       ?? 'Ready to Build Your Growth Engine?';
const ctaSubheading    = cta?.subheading    ?? "Stop waiting for referrals. Build a predictable system that brings your ideal clients to you. Book a free, no-obligation strategy call to see if it's a good fit.";
const ctaLabel         = cta?.ctaLabel      ?? 'Book Your Free Strategy Call';
const ctaUrl           = cta?.ctaUrl        ?? 'https://calendly.com/manolt/15min';
const ctaGuaranteeText = cta?.guaranteeText ?? "Risk-Free Guarantee: Full refund if the 5+ lead goal isn't met in 90 days.";
---

<section class="py-20 bg-gray-950 border-t border-gray-800">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-gray-900 rounded-2xl p-10 md:p-16 text-center border border-gray-800">
      <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">
        {ctaHeading}
      </h2>
      <p class="text-lg text-brand-gray max-w-2xl mx-auto mb-10">
        {ctaSubheading}
      </p>
      <a
        href={ctaUrl}
        class="inline-block bg-brand-lime text-black font-bold px-10 py-5 rounded-full glow-button hover:opacity-90 transition-opacity text-lg"
      >
        {ctaLabel}
      </a>
      <p class="mt-6 text-brand-gray text-sm">
        🛡️ {ctaGuaranteeText}
      </p>
    </div>
  </div>
</section>

<style>
  .glow-button {
    box-shadow: 0 0 15px rgba(190,242,100,0.4), 0 0 5px rgba(190,242,100,0.6);
  }
</style>
