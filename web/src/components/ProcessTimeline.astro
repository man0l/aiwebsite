---
interface Props {
  process: any;
}
const { process } = Astro.props;

const steps: any[] = process?.steps ?? [];
---

<section id="process" class="py-20 bg-brand-dark border-t border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    {process?.eyebrow && (
      <p class="text-center text-brand-lime font-bold text-sm uppercase tracking-wide mb-4">
        {process.eyebrow}
      </p>
    )}
    {process?.heading && (
      <h2 class="text-3xl md:text-5xl font-display font-bold text-white text-center mb-4">
        {process.heading}
      </h2>
    )}
    {process?.subheading && (
      <p class="text-brand-gray text-lg text-center max-w-2xl mx-auto mb-16">
        {process.subheading}
      </p>
    )}

    <div class="space-y-20">
      {steps.map((step: any, i: number) => {
        const cards: any[] = step.cards ?? [];
        const isEven = i % 2 === 0;
        return (
          <div class={`flex flex-col md:flex-row ${!isEven ? 'md:flex-row-reverse' : ''} gap-10 items-start`}>
            <!-- Text side -->
            <div class="flex-1">
              <!-- Step number badge -->
              <div class="flex items-center gap-4 mb-4">
                <span class="w-10 h-10 rounded-full bg-brand-lime text-black font-display font-bold text-lg flex items-center justify-center flex-shrink-0">
                  {i + 1}
                </span>
                {step.dateRange && (
                  <span class="text-brand-lime text-sm font-semibold">{step.dateRange}</span>
                )}
              </div>
              {step.title && (
                <h3 class="text-2xl font-display font-bold text-white mb-3">{step.title}</h3>
              )}
              {step.description && (
                <p class="text-brand-gray">{step.description}</p>
              )}
            </div>

            <!-- Cards side -->
            {cards.length > 0 && (
              <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-4">
                {cards.map((card: any) => (
                  <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
                    {card.title && (
                      <p class="text-white font-bold mb-2">{card.title}</p>
                    )}
                    {card.text && (
                      <p class="text-brand-gray text-sm">{card.text}</p>
                    )}
                  </div>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
