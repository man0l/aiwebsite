---
interface Props {
  systems: any;
}
const { systems } = Astro.props;

const tabs: any[] = systems?.tabs?.length ? systems.tabs : [
  {
    tabId: 'email', emoji: '✉️', label: 'Niche Outreach',
    title: 'Niche-Specific Decision Maker Outreach',
    body: "Bypass gatekeepers and land in owners' inboxes with AI-personalized outreach tied to vertical pain (missed calls, rising CPL).",
    bullets: [
      { text: 'Decision-Maker Sourcing: Data-backed lists of owners and partners—not generic front-desk contacts.' },
      { text: 'Pain-Point Personalization: Sequences reference vertical-specific problems to drive replies.' },
    ],
    miniCaseStudyLabel: 'ClickROI · Construction',
    miniCaseStudyText: 'Used this inbox-ready system to bypass manual prospecting and book contractor meetings without burning out their team.',
  },
  {
    tabId: 'linkedin', emoji: '🔗', label: 'Authority',
    title: 'Vertical Authority Positioning',
    body: 'Own your niche on LinkedIn so sales calls start with trust, not price pressure.',
    bullets: [
      { text: 'Niche Positioning: Profiles rewritten to signal relevance to contractors, legal, dental, and hospitality owners.' },
      { text: 'Automated Warm-Up: Safe, steady outreach to 500+ decision-makers monthly.' },
    ],
    miniCaseStudyLabel: null,
    miniCaseStudyText: null,
  },
  {
    tabId: 'content', emoji: '🤖', label: 'Educational Assets',
    title: 'Pain-Point Educational Assets',
    body: 'AI-assisted content that tackles immediate threats (AI search, patient loss) and nurtures leads before the call.',
    bullets: [
      { text: 'AI Drafting, Human Proof: Expert editors refine AI drafts into authoritative guides that win trust.' },
      { text: 'Multi-Channel Nurture: Assets shipped across email, LinkedIn, and retargeting to warm outbound prospects.' },
    ],
    miniCaseStudyLabel: 'Local Click Studio · Med Spas',
    miniCaseStudyText: 'Deployed AI-assisted nurture to fix speed-to-lead, capturing patient inquiries instantly and increasing booked consults.',
  },
];
---

<section id="systems" class="py-20 bg-gray-950 border-t border-gray-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-5xl font-display font-bold text-white text-center mb-4">
      {systems?.heading ?? 'Your AI-Powered Client Acquisition System'}
    </h2>
    <p class="text-brand-gray text-lg text-center max-w-2xl mx-auto mb-12">
      {systems?.subheading ?? 'Built for PPC, SEO, and digital agencies serving local businesses. Each component tackles the biggest blockers to scaling fulfillment-heavy, service-based models.'}
    </p>

    {tabs.length > 0 && (
      <>
        <!-- Tab buttons -->
        <div class="flex flex-wrap gap-3 justify-center mb-10">
          {tabs.map((t: any, i: number) => (
            <button
              class={`system-tab px-5 py-2.5 rounded-full border font-semibold text-sm transition-colors ${i === 0 ? 'active-tab' : 'border-gray-700 text-brand-gray hover:text-white hover:border-gray-500'}`}
              data-tab={t.tabId}
            >
              {t.emoji && <span class="mr-2">{t.emoji}</span>}
              {t.label}
            </button>
          ))}
        </div>

        <!-- Tab panels -->
        <div>
          {tabs.map((t: any, i: number) => {
            const bullets: any[] = t.bullets ?? [];
            const miniCase = t.miniCaseStudy;
            return (
              <div id={t.tabId} class={`system-content ${i !== 0 ? 'hidden' : ''}`}>
                <div class="bg-gray-900 rounded-2xl p-8 border border-gray-800">
                  {t.title && (
                    <h3 class="text-2xl font-display font-bold text-white mb-4">{t.title}</h3>
                  )}
                  {t.body && (
                    <p class="text-brand-gray mb-6">{t.body}</p>
                  )}
                  {bullets.length > 0 && (
                    <ul class="space-y-3 mb-6">
                      {bullets.map((b: any) => (
                        <li class="flex items-start gap-3 text-brand-light">
                          <span class="flex-shrink-0 w-5 h-5 rounded-full bg-brand-lime text-black text-xs font-bold flex items-center justify-center mt-0.5">✓</span>
                          {b.text ?? b}
                        </li>
                      ))}
                    </ul>
                  )}
                  {miniCase && (
                    <div class="bg-gray-800 rounded-xl p-5 border border-gray-700">
                      <p class="text-brand-lime font-bold text-xs uppercase tracking-wide mb-2">
                        {miniCase.label ?? 'Case Study'}
                      </p>
                      <p class="text-white font-semibold">{miniCase.title}</p>
                      {miniCase.body && (
                        <p class="text-brand-gray text-sm mt-2">{miniCase.body}</p>
                      )}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </>
    )}
  </div>
</section>

<style>
  .active-tab {
    color: #BEF264 !important;
    border-color: #BEF264 !important;
  }
</style>

<script type="module">
  document.querySelectorAll('.system-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.system-content').forEach(p => p.classList.add('hidden'));
      document.querySelectorAll('.system-tab').forEach(b => {
        b.classList.remove('active-tab');
        b.style.color = '';
        b.style.borderColor = '';
      });
      document.getElementById(btn.dataset.tab).classList.remove('hidden');
      btn.classList.add('active-tab');
    });
  });
</script>
