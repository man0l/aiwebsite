---
import Layout from '../../components/Layout.astro';
import { getBlogPosts, getGlobal, STRAPI_URL } from '../../lib/strapi.ts';

export async function getStaticPaths() {
  let posts: any[] = [];
  try {
    posts = await getBlogPosts();
  } catch (e) {
    // Strapi not available at build time — return empty paths
    console.warn('[blog/[slug]] Strapi unavailable, building with 0 post pages:', (e as Error).message);
  }
  return posts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

let global: any = null;
try { global = await getGlobal(); } catch {}
const nav: any[] = global?.nav ?? [];

const coverUrl = post.coverImage?.url ? `${STRAPI_URL}${post.coverImage.url}` : null;

const authorName: string = post.author?.name ?? '';
const authorAvatarUrl: string | null = post.author?.avatar?.url
  ? `${STRAPI_URL}${post.author.avatar.url}`
  : null;

const categories: string[] = post.categories?.map((c: any) => c.name) ?? [];

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const seo = post.seo ?? {};
---
<Layout
  title={seo.metaTitle ?? post.title}
  description={seo.metaDescription ?? post.excerpt}
  image={seo.metaImage?.url ? `${STRAPI_URL}${seo.metaImage.url}` : coverUrl ?? undefined}
  nav={nav.map((n: any) => ({ label: n.label, href: n.href }))}
  siteName={global?.siteName}
>
  <article class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      {categories.length > 0 && (
        <div class="flex gap-2 mb-4">
          {categories.map((cat) => (
            <span class="text-brand-lime text-xs font-bold uppercase tracking-wide">{cat}</span>
          ))}
        </div>
      )}

      <h1 class="text-4xl md:text-5xl font-display font-bold text-white leading-tight">{post.title}</h1>

      <div class="mt-6 flex items-center gap-4 text-brand-gray text-sm">
        {authorAvatarUrl && (
          <img src={authorAvatarUrl} alt={authorName} class="w-8 h-8 rounded-full object-cover" />
        )}
        {authorName && <span>{authorName}</span>}
        {date && <span>· {date}</span>}
        {post.readingTime && <span>· {post.readingTime} min read</span>}
      </div>

      {coverUrl && (
        <img src={coverUrl} alt={post.title} class="mt-8 w-full rounded-2xl object-cover max-h-96" />
      )}

      {post.content && (
        <div
          class="mt-10 prose prose-invert prose-lg max-w-none prose-headings:font-display prose-a:text-brand-lime"
          set:html={post.content}
        />
      )}

      <div class="mt-16 pt-8 border-t border-gray-800">
        <a href="/blog" class="text-brand-lime hover:underline text-sm font-medium">← Back to Blog</a>
      </div>
    </div>
  </article>
</Layout>
