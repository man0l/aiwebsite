---
import Layout from '../../components/Layout.astro';
import { getBlogPosts, getGlobal, STRAPI_URL } from '../../lib/strapi.ts';

let posts: any[] = [], global: any = null;
try { [posts, global] = await Promise.all([getBlogPosts(), getGlobal()]); } catch {}
const nav: any[] = global?.nav ?? [];
---
<Layout
  title={`Blog — ${global?.siteName ?? 'FlowCraft Pro'}`}
  description="Insights on AI automation and agency growth"
  nav={nav.map((n: any) => ({ label: n.label, href: n.href }))}
  siteName={global?.siteName}
>
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white text-center mb-12">Blog</h1>

      {posts.length === 0 && (
        <p class="text-brand-gray text-center">No posts published yet.</p>
      )}

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post: any) => {
          const coverUrl = post.coverImage?.url
            ? `${STRAPI_URL}${post.coverImage.url}`
            : null;
          const categories: string[] = post.categories?.map((c: any) => c.name) ?? [];
          const date = post.publishedAt
            ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
            : '';

          return (
            <a href={`/blog/${post.slug}`} class="group block bg-gray-900 rounded-2xl overflow-hidden border border-gray-800 hover:border-brand-lime transition-colors">
              {coverUrl && (
                <img src={coverUrl} alt={post.title} class="w-full h-48 object-cover" />
              )}
              <div class="p-6">
                {categories.length > 0 && (
                  <div class="flex gap-2 mb-3">
                    {categories.map((cat) => (
                      <span class="text-brand-lime text-xs font-bold uppercase tracking-wide">{cat}</span>
                    ))}
                  </div>
                )}
                <h2 class="text-xl font-bold text-white group-hover:text-brand-lime transition-colors">{post.title}</h2>
                {post.excerpt && <p class="mt-2 text-brand-gray text-sm line-clamp-3">{post.excerpt}</p>}
                <div class="mt-4 flex items-center gap-3 text-xs text-brand-gray">
                  {date && <span>{date}</span>}
                  {post.readingTime && <span>· {post.readingTime} min read</span>}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
